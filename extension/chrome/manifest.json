{
  "manifest_version": 3,
  "name": "Alchemy Web Clipper",
  "version": "1.0.0",
  "description": "Send the current page, a link, or selected text to an Alchemy notebook as a source.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Add this page to Alchemy"
  },
  "permissions": ["contextMenus", "activeTab"],
  "background": {
    "service_worker": "background.js"
  }
}
