<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Mac sources drive Notes (and Calendar's JXA fallback) over AppleEvents
	     via the cider subprocess; hardened-runtime apps must declare it or the
	     send fails silently with no consent prompt. -->
	<key>com.apple.security.automation.apple-events</key>
	<true/>
</dict>
</plist>
