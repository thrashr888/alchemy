{
  "name": "fixture-core",
  "description": "Golden queries over the built-in fixture corpus in evals.rs: exact identifiers, paraphrase, section-targeted, metadata/title intent, and multi-source (multihop) questions.",
  "queries": [
    {
      "query": "what is the status of INV-2024-0042?",
      "kind": "exact",
      "relevant": [
        { "source_title": "Acme Invoices Q3", "must_contain": "INV-2024-0042" }
      ]
    },
    {
      "query": "which invoice is overdue for Globex?",
      "kind": "exact",
      "relevant": [
        { "source_title": "Acme Invoices Q3", "must_contain": "INV-2024-0051" }
      ]
    },
    {
      "query": "what should happen after ERR-503-BACKOFF?",
      "kind": "exact",
      "relevant": [
        { "source_title": "Acme Invoices Q3", "must_contain": "ERR-503-BACKOFF" }
      ]
    },
    {
      "query": "what service uses port 32400?",
      "kind": "exact",
      "relevant": [
        { "source_title": "Home Network Guide", "must_contain": "32400" }
      ]
    },
    {
      "query": "how much vacation time do employees earn?",
      "kind": "paraphrase",
      "relevant": [
        { "source_title": "Employee Handbook", "must_contain": "paid time off" }
      ]
