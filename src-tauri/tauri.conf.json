{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Alchemy",
  "version": "0.9.0",
  "identifier": "com.thrashr888.alchemy",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Alchemy",
        "width": 1280,
        "height": 820,
        "minWidth": 1040,
        "minHeight": 640,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 20,
          "y": 18
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "libs/libpdfium.dylib"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEEwNDZCMTNDQ0QxMjM3OTUKUldTVk54TE5QTEZHb05tdmpEdEVZTWlCUmQvVU9uOWdZek5Tb3FvMm1jSXRhb3FwRW4vanQxS24K",
      "endpoints": [
        "https://github.com/thrashr888/alchemy/releases/latest/download/latest.json"
      ]
    }
  }
}
